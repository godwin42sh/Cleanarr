# ---- Database (PostgreSQL) ----
# For docker compose: the password is defined ONCE here and shared by the db
# container and the backend (which builds its DATABASE_URL from these three).
POSTGRES_USER=cleanarr
POSTGRES_PASSWORD=cleanarr
POSTGRES_DB=cleanarr

# For running the backend directly on the host (non-docker dev), Prisma uses
# this connection string. It is ignored by docker compose (the backend derives
# its own from POSTGRES_* above). Keep the password in sync with POSTGRES_PASSWORD.
DATABASE_URL=postgresql://cleanarr:cleanarr@localhost:5432/cleanarr?schema=public

# ---- qBittorrent Web API ----
# Base URL of the qBittorrent WebUI (no trailing slash)
QB_URL=http://localhost:8080
QB_USERNAME=admin
QB_PASSWORD=adminadmin

# ---- Scanner ----
# Comma-separated list of directories to scan for unused downloads
SCAN_DIRS=/mnt/Nas/Media/Shows/.downloads,/mnt/Nas/Media/Movies/.downloads,/mnt/Nas/Media/Music/.downloads
# A file is considered "old enough" to clean once it is older than this many days
SCAN_DAYS=7
# Comma-separated media extensions to consider (without the leading dot)
MEDIA_EXTENSIONS=mkv,mp4,flac,m4a,mp3,avi,mov,wmv,webm,mpeg,mpg,mk3d,mka,opus,wav,aac,alac

# ---- Scan cron ----
# Cron expression for the periodic scan (default: every day at 04:00).
# The cron only scans and stores candidates — cleaning is always manual.
CLEANUP_CRON=0 4 * * *

# ---- Server ----
PORT=3000
# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:5173
