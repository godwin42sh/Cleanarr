# ---- qBittorrent Web API ----
# Base URL of the qBittorrent WebUI (no trailing slash)
QB_URL=http://localhost:8080
QB_USERNAME=admin
QB_PASSWORD=adminadmin

# ---- Scanner ----
# Comma-separated list of directories to scan for unused downloads
SCAN_DIRS=/mnt/Nas/Media/Shows/.downloads,/mnt/Nas/Media/Movies/.downloads,/mnt/Nas/Media/Music/.downloads
# A file is considered "old enough" to clean once it is older than this many days
SCAN_DAYS=7
# Comma-separated media extensions to consider (without the leading dot)
MEDIA_EXTENSIONS=mkv,mp4,flac,m4a,mp3,avi,mov,wmv,webm,mpeg,mpg,mk3d,mka,opus,wav,aac,alac

# ---- Cleanup cron ----
# Cron expression for the periodic scan (default: every day at 04:00)
CLEANUP_CRON=0 4 * * *
# When true, the cron will automatically clean every candidate it finds.
# When false (default) the cron only refreshes the candidate list.
CLEANUP_AUTO=false

# ---- Server ----
PORT=3000
# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:5173
