{
  "name": "cleanarr",
  "version": "0.1.0",
  "private": true,
  "description": "Scan a media library for unused (unlinked) downloads and clean the matching torrents from qBittorrent.",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,json,css}\" \"*.{json,md,yaml,yml}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,json,css}\" \"*.{json,md,yaml,yml}\"",
    "dev:backend": "pnpm --filter @cleanarr/backend start:dev",
    "dev:frontend": "pnpm --filter @cleanarr/frontend dev"
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  }
}
